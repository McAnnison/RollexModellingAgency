# MongoDB connection string
# For local development, use: mongodb://127.0.0.1:27017/rollex
# For MongoDB Atlas, use:    mongodb+srv://<user>:<password>@cluster.mongodb.net/rollex
MONGODB_URI=mongodb://127.0.0.1:27017/rollex

# Secret used to sign admin JWT tokens — change to a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# SendGrid (leave blank to skip email sending)
SENDGRID_KEY=
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_ADMIN=admin@yourdomain.com

# Directory where uploaded files are stored (defaults to ./uploads inside functions/)
# UPLOADS_DIR=/var/data/rollex-uploads

# HTTP port (defaults to 3000)
PORT=3000

# Allowed CORS origin(s).
# Set to your frontend URL in production, e.g. https://www.rollexmodellingagency.com
# Multiple origins: CORS_ORIGIN=https://example.com,https://www.example.com
CORS_ORIGIN=*
